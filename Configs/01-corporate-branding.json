{
  "$schema": "https://alttabtowork.com/schemas/registry-config-v1.json",
  "version": "1.0",
  "author": "Haakon Wibe",
  "description": "Corporate branding and baseline settings for Hawkweave organization",
  "created": "2026-01-28",
  "settings": [
    {
      "name": "Corporate Branding - Machine",
      "description": "Machine-level corporate identification settings",
      "scope": "Machine",
      "path": "SOFTWARE\\Hawkweave\\Corporate",
      "action": "Set",
      "values": [
        {
          "name": "ManagedBy",
          "type": "String",
          "data": "Hawkweave IT Department"
        },
        {
          "name": "ConfiguredDate",
          "type": "String",
          "data": "{{DATE}}",
          "skipDetection": true
        },
        {
          "name": "EngineVersion",
          "type": "String",
          "data": "{{ENGINEVERSION}}"
        },
        {
          "name": "ConfigVersion",
          "type": "DWord",
          "data": 1
        },
        {
          "name": "ComplianceRequired",
          "type": "DWord",
          "data": 1
        }
      ]
    },
    {
      "name": "Corporate Branding - User",
      "description": "User-level corporate identification (applied to all users)",
      "scope": "User",
      "path": "SOFTWARE\\Hawkweave\\Corporate",
      "action": "Set",
      "values": [
        {
          "name": "Configured",
          "type": "DWord",
          "data": 1
        },
        {
          "name": "ConfiguredDate",
          "type": "String",
          "data": "{{DATETIME}}",
          "skipDetection": true
        }
      ]
    },
    {
      "name": "Corporate Branding - Default User",
      "description": "Applied to new user profiles when they first log in",
      "scope": "DefaultUser",
      "path": "SOFTWARE\\Hawkweave\\Corporate",
      "action": "Set",
      "values": [
        {
          "name": "Configured",
          "type": "DWord",
          "data": 1
        },
        {
          "name": "ProfileSource",
          "type": "String",
          "data": "DefaultUserTemplate"
        }
      ]
    }
  ]
}
